<!DOCTYPE html>
<html lang="en">
  <%- include('partials/head') %>

  <body>
    <%- include('partials/nav') %>

    <main class="map-main">

      <div class="map-search-bar">
        <input type="text" id="map-search" placeholder="Search by name, category, address or tag..." oninput="filterCards()" />
        <div class="map-filter-wrap">
          <button class="map-filter-btn" id="map-filter-btn" onclick="toggleFilterPanel(event)" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="11" y1="18" x2="13" y2="18"/></svg>
            Filters
            <span class="map-filter-count" id="map-filter-count" style="display:none;">0</span>
          </button>
          <div class="map-filter-panel" id="map-filter-panel">
            <p class="map-filter-section-label">Category</p>
            <label class="map-filter-check"><input type="checkbox" value="digital help"       onchange="filterCards()"> Digital Help</label>
            <label class="map-filter-check"><input type="checkbox" value="food support"       onchange="filterCards()"> Food Support</label>
            <label class="map-filter-check"><input type="checkbox" value="warm / cool spaces" onchange="filterCards()"> Warm / Cool Spaces</label>
            <label class="map-filter-check"><input type="checkbox" value="advice"             onchange="filterCards()"> Advice</label>
            <label class="map-filter-check"><input type="checkbox" value="community events"   onchange="filterCards()"> Community Events</label>
            <label class="map-filter-check"><input type="checkbox" value="accessibility"      onchange="filterCards()"> Accessibility</label>
            <div class="map-filter-divider"></div>
            <p class="map-filter-section-label">Amenities</p>
            <label class="map-filter-check"><input type="checkbox" id="f-free"     onchange="filterCards()"> Free</label>
            <label class="map-filter-check"><input type="checkbox" id="f-wifi"     onchange="filterCards()"> Wi-Fi</label>
            <label class="map-filter-check"><input type="checkbox" id="f-toilets"  onchange="filterCards()"> Toilets</label>
            <label class="map-filter-check"><input type="checkbox" id="f-stepfree" onchange="filterCards()"> Step-free access</label>
            <label class="map-filter-check"><input type="checkbox" id="f-printer"  onchange="filterCards()"> Printer</label>
            <button class="map-filter-clear" onclick="clearFilters()" type="button">Clear all</button>
          </div>
        </div>
      </div>

      <div class="map-layout">

        <!-- Left: service list -->
        <div class="map-list" id="map-list">
          <% if (services.length === 0) { %>
            <p class="map-empty">No services have been added yet. Visit <a href="/admin">Admin</a> to add some.</p>
          <% } else { %>
            <% services.forEach(function(service) { %>
              <div class="map-card" id="card-<%= service._id %>"
                   data-name="<%= service.name.toLowerCase() %>"
                   data-category="<%= service.category.toLowerCase() %>"
                   data-address="<%= (service.address || '').toLowerCase() %>"
                   data-free="<%= service.isFree ? '1' : '0' %>"
                   data-wifi="<%= service.hasWifi ? '1' : '0' %>"
                   data-toilets="<%= service.hasToilets ? '1' : '0' %>"
                   data-stepfree="<%= service.hasStepFreeAccess ? '1' : '0' %>"
                   data-printer="<%= service.hasPrinter ? '1' : '0' %>"
                   onclick="focusService('<%= service._id %>')">

                <div class="map-card-body">
                  <div class="map-card-header">
                    <strong class="map-card-name"><%= service.name %></strong>
                    <span class="map-card-tag"><%= service.category %></span>
                  </div>

                  <% if (service.description) { %>
                    <p class="map-card-desc"><%= service.description.length > 100 ? service.description.substring(0, 100) + '…' : service.description %></p>
                  <% } %>

                  <% if (service.address) { %>
                    <span class="map-card-address">📍 <%= service.address %></span>
                  <% } %>

                  <% if (service.openingTimes) { %>
                    <span class="map-card-hours">🕐 <%= service.openingTimes %></span>
                  <% } %>

                  <div class="map-card-badges">
                    <% if (service.isFree) { %><span class="badge badge-green">Free</span><% } %>
                    <% if (service.hasWifi) { %><span class="badge">WiFi</span><% } %>
                    <% if (service.hasStepFreeAccess) { %><span class="badge">Step-free</span><% } %>
                    <% if (service.hasToilets) { %><span class="badge">Toilets</span><% } %>
                    <% if (service.hasPrinter) { %><span class="badge">Printer</span><% } %>
                  </div>

                  <% if (service.address) { %>
                    <a class="map-directions-btn"
                       href="https://www.google.com/maps/dir/?api=1&destination=<%= encodeURIComponent(service.address + ', Birmingham, UK') %>&travelmode=walking"
                       target="_blank" rel="noopener"
                       onclick="event.stopPropagation()">
                      Get Directions in Google Maps ↗
                    </a>
                  <% } %>
                </div>
              </div>
            <% }) %>
          <% } %>
        </div>

        <!-- Right: map -->
        <div class="map-right">
          <div id="ladywood-map"></div>
        </div>

      </div>
    </main>

    <%- include('partials/footer') %>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script id="services-data" type="application/json"><%- JSON.stringify(services) %></script>

    <script>
      // Services data passed in from the server
      const services = JSON.parse(document.getElementById('services-data').textContent);
      const markers = {}; // stores Leaflet markers keyed by service ID

      // Set up the map centred on Ladywood
      const map = L.map('ladywood-map').setView([52.4777, -1.9251], 14);

      // Street and satellite tile layers
      const streetLayer = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '&copy; OpenStreetMap contributors'
      });

      const satelliteLayer = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
        maxZoom: 19,
        attribution: '&copy; Esri &mdash; Source: Esri, Maxar, Earthstar Geographics'
      });

      // Start on street view, with a toggle control to switch between layers
      streetLayer.addTo(map);
      L.control.layers(
        { 'Street': streetLayer, 'Satellite': satelliteLayer },
        {},
        { position: 'topright' }
      ).addTo(map);

      // Show a blue dot for the user's current location if allowed
      if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(pos => {
          L.circleMarker([pos.coords.latitude, pos.coords.longitude], {
            radius: 9, color: '#1f2933', fillColor: '#2563eb', fillOpacity: 1, weight: 2
          }).addTo(map).bindPopup('<strong>Your location</strong>');
        });
      }

      // Small helper to pause between geocoding requests (Nominatim rate limit)
      function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

      // Cache geocoded coordinates in localStorage so pins load instantly on repeat visits
      const GEO_CACHE_KEY = 'cl_geo_cache';
      function loadCache() { try { return JSON.parse(localStorage.getItem(GEO_CACHE_KEY) || '{}'); } catch { return {}; } }
      function saveCache(cache) { try { localStorage.setItem(GEO_CACHE_KEY, JSON.stringify(cache)); } catch {} }

      // Place a marker on the map and bind a popup with service details
      function addMarker(service, coords) {
        const marker = L.marker(coords).addTo(map);
        marker.bindPopup(`
          <div style="min-width:180px">
            <strong style="font-size:0.95rem">${service.name}</strong><br>
            <span style="color:#666;font-size:0.8rem">${service.category}</span><br>
            <span style="font-size:0.8rem">${service.address}</span><br><br>
            <a href="https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(service.address + ', Birmingham, UK')}&travelmode=walking"
               target="_blank" rel="noopener"
               style="display:block;background:#1f2933;color:white;padding:6px 10px;border-radius:6px;text-align:center;text-decoration:none;font-size:0.85rem;">
              Get Directions ↗
            </a>
          </div>
        `);
        markers[service._id] = marker;
      }

      // Geocode all service addresses using Nominatim (free OpenStreetMap geocoder).
      // Cached addresses load instantly. New ones are fetched one at a time to stay within the 1 req/sec limit.
      async function geocodeAllServices() {
        const cache = loadCache();
        const toFetch = [];

        for (const service of services) {
          if (!service.address) continue;
          if (cache[service.address]) {
            // Already geocoded, use cached coords
            addMarker(service, cache[service.address]);
          } else {
            toFetch.push(service);
          }
        }

        for (const service of toFetch) {
          try {
            // Append Birmingham if not already in the address to improve accuracy
            const query = service.address.toLowerCase().includes('birmingham') ? service.address : service.address + ', Birmingham, UK';
            const url = `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}&limit=1&countrycodes=gb`;
            const res = await fetch(url, { headers: { 'Accept-Language': 'en' } });
            const data = await res.json();
            if (data.length) {
              const coords = [parseFloat(data[0].lat), parseFloat(data[0].lon)];
              cache[service.address] = coords;
              saveCache(cache);
              addMarker(service, coords);
            }
          } catch (e) {}
          await sleep(1000); // wait 1s between requests
        }
      }

      geocodeAllServices();

      // When a card is clicked, pan the map to that marker and highlight the card
      function focusService(id) {
        const marker = markers[id];
        if (marker) {
          map.setView(marker.getLatLng(), 16);
          marker.openPopup();
        }
        document.querySelectorAll('.map-card').forEach(c => c.classList.remove('map-card-active'));
        const card = document.getElementById('card-' + id);
        if (card) {
          card.classList.add('map-card-active');
          card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      }

      // Keywords used to match text search queries against amenity tags
      const tagKeywords = { free: ['free'], wifi: ['wifi', 'wi-fi'], toilets: ['toilet'], stepfree: ['step-free', 'step free', 'disabled', 'accessible'], printer: ['printer'] };

      // Toggle the filter dropdown open/closed
      function toggleFilterPanel(e) {
        e.stopPropagation();
        document.getElementById('map-filter-panel').classList.toggle('open');
      }

      // Close the filter panel if the user clicks anywhere outside it
      document.addEventListener('click', function(e) {
        const panel = document.getElementById('map-filter-panel');
        const btn = document.getElementById('map-filter-btn');
        if (!panel.contains(e.target) && !btn.contains(e.target)) panel.classList.remove('open');
      });

      // Uncheck all filters and refresh the list
      function clearFilters() {
        document.querySelectorAll('#map-filter-panel input[type="checkbox"]').forEach(cb => cb.checked = false);
        filterCards();
      }

      // Filter cards by search text, selected categories, and amenity checkboxes.
      // A card only shows if it matches all three.
      function filterCards() {
        const q = document.getElementById('map-search').value.toLowerCase();

        // Category checkboxes have no id, so that's how we tell them apart from amenity ones
        const catBoxes = [...document.querySelectorAll('#map-filter-panel input[type="checkbox"]:not([id])')].filter(cb => cb.checked).map(cb => cb.value);

        // Checked amenity boxes
        const amenities = { free: document.getElementById('f-free').checked, wifi: document.getElementById('f-wifi').checked, toilets: document.getElementById('f-toilets').checked, stepfree: document.getElementById('f-stepfree').checked, printer: document.getElementById('f-printer').checked };

        // Update the active-filter count badge on the button
        const activeCount = catBoxes.length + Object.values(amenities).filter(Boolean).length;
        const countEl = document.getElementById('map-filter-count');
        countEl.style.display = activeCount ? 'inline-flex' : 'none';
        countEl.textContent = activeCount;

        document.querySelectorAll('.map-card').forEach(card => {
          // Build a string of tag keywords so the text search can match amenities too
          const tagText = Object.entries(tagKeywords).filter(([k]) => card.dataset[k] === '1').flatMap(([,v]) => v).join(' ');
          const textMatch = !q || card.dataset.name.includes(q) || card.dataset.address.includes(q) || card.dataset.category.includes(q) || tagText.includes(q);
          const catMatch = catBoxes.length === 0 || catBoxes.some(c => card.dataset.category.includes(c));
          const amenityMatch = Object.entries(amenities).every(([k, checked]) => !checked || card.dataset[k] === '1');
          card.style.display = (textMatch && catMatch && amenityMatch) ? '' : 'none';
        });
      }
    </script>
  </body>
</html>
