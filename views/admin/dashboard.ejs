<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head') %>

  <body>
    <%- include('../partials/nav') %>

    <main>
      <h1>Admin Dashboard</h1>

      <p>Use this page to add or remove services from CommunityLink Ladywood.</p>

      <% if (error) { %>
        <p class="error"><%= error %></p>
      <% } %>

      <form action="/admin/logout" method="POST">
        <button type="submit">Log out</button>
      </form>

      <section class="form-card">
        <h2>Add a service</h2>

        <form action="/admin/services" method="POST">
          <label for="name">Service name *</label>
          <input type="text" id="name" name="name" required>

          <label for="category">Category *</label>
          <select id="category" name="category" required>
            <option value="Digital Help">Digital Help</option>
            <option value="Food Support">Food Support</option>
            <option value="Warm / Cool Spaces">Warm / Cool Spaces</option>
            <option value="Advice">Advice</option>
            <option value="Community Events">Community Events</option>
            <option value="Accessibility">Accessibility</option>
          </select>

          <label for="description">Description *</label>
          <textarea id="description" name="description" required></textarea>

          <label for="address">Address *</label>
          <input type="text" id="address" name="address" required>

          <label for="phone">Phone</label>
          <input type="text" id="phone" name="phone">

          <label for="openingTimes">Opening times *</label>
          <input
            type="text"
            id="openingTimes"
            name="openingTimes"
            placeholder="Example: Monday to Friday, 10:00–16:00"
            required
          >

          <fieldset>
            <legend>Service details</legend>

            <label>
              <input type="checkbox" name="isFree" checked>
              Free service
            </label>

            <label>
              <input type="checkbox" name="hasWifi">
              Has Wi-Fi
            </label>

            <label>
              <input type="checkbox" name="hasPrinter">
              Has printer
            </label>

            <label>
              <input type="checkbox" name="hasToilets">
              Has toilets
            </label>

            <label>
              <input type="checkbox" name="hasStepFreeAccess">
              Step-free access
            </label>
          </fieldset>

          <label for="accessibilityNotes">Accessibility notes</label>
          <textarea
            id="accessibilityNotes"
            name="accessibilityNotes"
            placeholder="Example: Step-free entrance and accessible toilet available."
          ></textarea>

          <button type="submit">Add service</button>
        </form>
      </section>

      <section>
        <h2>Current services</h2>

        <% if (services.length === 0) { %>
          <p>No services have been added yet.</p>
        <% } else { %>
          <table>
            <thead>
              <tr>
                <th>Service</th>
                <th>Category</th>
                <th>Last updated</th>
                <th>Actions</th>
              </tr>
            </thead>

            <tbody>
              <% services.forEach((service) => { %>
                <tr>
                  <td><%= service.name %></td>
                  <td><%= service.category %></td>
                  <td>
                    <%= service.updatedAt ? new Date(service.updatedAt).toLocaleDateString('en-GB') : 'N/A' %>
                  </td>
                  <td>
                    <a href="/services/<%= service._id %>">View</a>

                    <form
                      action="/admin/services/<%= service._id %>/delete"
                      method="POST"
                      style="display: inline;"
                      onsubmit="return confirm('Are you sure you want to delete this service?');"
                    >
                      <button type="submit">Delete</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </section>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>