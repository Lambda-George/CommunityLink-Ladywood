<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head') %>

  <body>
    <%- include('../partials/nav') %>

    <main>

      <div class="services-hero">
        <div class="admin-hero-row">
          <div>
            <h1>Admin Dashboard</h1>
            <p>Add or remove services from CommunityLink Ladywood.</p>
          </div>
          <form action="/admin/logout" method="POST">
            <button type="submit" class="btn-logout">Log out</button>
          </form>
        </div>
      </div>

      <div class="admin-body">

        <% if (error) { %>
          <p class="error"><%= error %></p>
        <% } %>

        <section class="admin-card">
          <h2>Add a service</h2>

          <form action="/admin/services" method="POST" class="admin-form">

            <div class="admin-form-row">
              <div class="admin-field">
                <label for="name">Service name *</label>
                <input type="text" id="name" name="name" required placeholder="e.g. Ladywood Library">
              </div>
              <div class="admin-field">
                <label for="category">Category *</label>
                <select id="category" name="category" required>
                  <option value="Digital Help">Digital Help</option>
                  <option value="Food Support">Food Support</option>
                  <option value="Warm / Cool Spaces">Warm / Cool Spaces</option>
                  <option value="Advice">Advice</option>
                  <option value="Community Events">Community Events</option>
                  <option value="Accessibility">Accessibility</option>
                </select>
              </div>
            </div>

            <div class="admin-field">
              <label for="description">Description *</label>
              <textarea id="description" name="description" required placeholder="Brief description of the service..."></textarea>
            </div>

            <div class="admin-form-row">
              <div class="admin-field">
                <label for="address">Address *</label>
                <input type="text" id="address" name="address" required placeholder="e.g. 123 High Street, Birmingham B1 1AA">
              </div>
              <div class="admin-field">
                <label for="phone">Phone</label>
                <input type="text" id="phone" name="phone" placeholder="e.g. 0121 000 0000">
              </div>
            </div>

            <div class="admin-field">
              <label for="openingTimes">Opening times *</label>
              <input type="text" id="openingTimes" name="openingTimes" required placeholder="e.g. Monday to Friday, 10:00–16:00">
            </div>

            <fieldset class="admin-fieldset">
              <legend>Service details</legend>
              <div class="admin-checks">
                <label class="filter-pill">
                  <input type="checkbox" name="isFree" checked>
                  <span>Free service</span>
                </label>
                <label class="filter-pill">
                  <input type="checkbox" name="hasWifi">
                  <span>Has Wi-Fi</span>
                </label>
                <label class="filter-pill">
                  <input type="checkbox" name="hasPrinter">
                  <span>Has printer</span>
                </label>
                <label class="filter-pill">
                  <input type="checkbox" name="hasToilets">
                  <span>Has toilets</span>
                </label>
                <label class="filter-pill">
                  <input type="checkbox" name="hasStepFreeAccess">
                  <span>Step-free access</span>
                </label>
              </div>
            </fieldset>

            <div class="admin-field">
              <label for="accessibilityNotes">Accessibility notes</label>
              <textarea id="accessibilityNotes" name="accessibilityNotes" placeholder="e.g. Step-free entrance and accessible toilet available."></textarea>
            </div>

            <button type="submit" class="btn-primary">Add service</button>

          </form>
        </section>

        <section class="admin-card">
          <h2>Current services</h2>

          <% if (services.length === 0) { %>
            <p style="color:#6b7280;">No services have been added yet.</p>
          <% } else { %>
            <div class="admin-table-wrap">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th>Service</th>
                    <th>Category</th>
                    <th>Last updated</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% services.forEach((service) => { %>
                    <tr>
                      <td><strong><%= service.name %></strong></td>
                      <td><span class="service-category"><%= service.category %></span></td>
                      <td><%= service.updatedAt ? new Date(service.updatedAt).toLocaleDateString('en-GB') : 'N/A' %></td>
                      <td class="admin-actions">
                        <a href="/services#service-<%= service._id %>" class="btn-view">View</a>
                        <form
                          action="/admin/services/<%= service._id %>/delete"
                          method="POST"
                          style="display:inline;"
                          onsubmit="return confirm('Are you sure you want to delete <%= service.name %>?');"
                        >
                          <button type="submit" class="btn-delete">Delete</button>
                        </form>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </section>

      </div>

    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
