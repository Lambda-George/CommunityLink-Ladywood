<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head') %>

  <body>
    <%- include('../partials/nav') %>

    <main>
      <div class="services-hero">
        <h1>Admin Login</h1>
        <p>Restricted to trusted service providers and project admins.</p>
      </div>

      <div class="login-wrap">
        <div class="admin-card">
          <h2>Sign in</h2>

          <% if (error) { %>
            <p class="login-error"><%= error %></p>
          <% } %>

          <form action="/admin/login" method="POST" class="admin-form">
            <div class="admin-field">
              <label for="password">Admin password</label>
              <input type="password" id="password" name="password" required placeholder="Enter password" />
            </div>
            <button type="submit" class="btn-primary" style="width:100%;justify-content:center;">Log in</button>
          </form>
        </div>
      </div>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
