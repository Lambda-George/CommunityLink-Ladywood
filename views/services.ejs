<!DOCTYPE html>
<html lang="en">
  <%- include('partials/head') %>

  <body>
    <%- include('partials/nav') %>

    <main>
      <h1>Find Help</h1>

      <% if (error) { %>
        <p class="error"><%= error %></p>
      <% } %>

      <form action="/services" method="GET" class="filter-form">
        <label for="search">Search</label>
        <input
          type="text"
          id="search"
          name="search"
          value="<%= query.search || '' %>"
          placeholder="Search by service, category or keyword"
        >

        <label for="category">Category</label>
        <select id="category" name="category">
          <option value="">All categories</option>
          <option value="Digital Help" <%= query.category === 'Digital Help' ? 'selected' : '' %>>Digital Help</option>
          <option value="Food Support" <%= query.category === 'Food Support' ? 'selected' : '' %>>Food Support</option>
          <option value="Warm / Cool Spaces" <%= query.category === 'Warm / Cool Spaces' ? 'selected' : '' %>>Warm / Cool Spaces</option>
          <option value="Advice" <%= query.category === 'Advice' ? 'selected' : '' %>>Advice</option>
          <option value="Community Events" <%= query.category === 'Community Events' ? 'selected' : '' %>>Community Events</option>
          <option value="Accessibility" <%= query.category === 'Accessibility' ? 'selected' : '' %>>Accessibility</option>
        </select>

        <div class="filter-checkboxes">
          <label class="checkbox-label">
            <input type="checkbox" name="free" value="true" <%= query.free === 'true' ? 'checked' : '' %>>
            Free services only
          </label>
          <label class="checkbox-label">
            <input type="checkbox" name="wifi" value="true" <%= query.wifi === 'true' ? 'checked' : '' %>>
            Has Wi-Fi
          </label>
          <label class="checkbox-label">
            <input type="checkbox" name="printer" value="true" <%= query.printer === 'true' ? 'checked' : '' %>>
            Has printer
          </label>
          <label class="checkbox-label">
            <input type="checkbox" name="toilets" value="true" <%= query.toilets === 'true' ? 'checked' : '' %>>
            Has toilets
          </label>
          <label class="checkbox-label">
            <input type="checkbox" name="stepFree" value="true" <%= query.stepFree === 'true' ? 'checked' : '' %>>
            Step-free access
          </label>
        </div>

        <button type="submit">Apply filters</button>
      </form>

      <section class="results">
        <h2><%= services.length %> result(s)</h2>

        <% if (services.length === 0) { %>
          <p>No services matched your search. Try removing a filter.</p>
        <% } %>

        <% services.forEach((service) => { %>
          <article class="service-card" id="service-<%= service._id %>">

            <div class="service-card-header">
              <div>
                <h3 class="service-name"><%= service.name %></h3>
                <span class="service-category"><%= service.category %></span>
              </div>
              <% if (service.isFree) { %>
                <span class="badge badge-free">Free</span>
              <% } %>
            </div>

            <p class="service-description"><%= service.description %></p>

            <p class="service-hours">
              <strong>Opening times:</strong> <%= service.openingTimes %>
            </p>

            <div class="amenity-badges">
              <span class="amenity <%= service.hasToilets ? 'amenity-yes' : 'amenity-no' %>">
                🚻 Toilets: <%= service.hasToilets ? 'Yes' : 'No' %>
              </span>
              <span class="amenity <%= service.hasStepFreeAccess ? 'amenity-yes' : 'amenity-no' %>">
                ♿ Disabled Access: <%= service.hasStepFreeAccess ? 'Yes' : 'No' %>
              </span>
              <span class="amenity <%= service.hasWifi ? 'amenity-yes' : 'amenity-no' %>">
                📶 Wi-Fi: <%= service.hasWifi ? 'Yes' : 'No' %>
              </span>
              <% if (service.hasPrinter) { %>
                <span class="amenity amenity-yes">🖨️ Printer: Yes</span>
              <% } %>
            </div>

            <details>
              <summary>View more details</summary>

              <div class="service-more-info">
                <p><strong>Address:</strong> <%= service.address %></p>

                <% if (service.phone) { %>
                  <p><strong>Phone:</strong> <a href="tel:<%= service.phone %>"><%= service.phone %></a></p>
                <% } %>

                <% if (service.accessibilityNotes) { %>
                  <p><strong>Accessibility notes:</strong> <%= service.accessibilityNotes %></p>
                <% } %>

                <p>
                  <strong>Last updated:</strong>
                  <%= service.updatedAt ? new Date(service.updatedAt).toLocaleDateString('en-GB') : 'Not recorded' %>
                </p>

                <button type="button" onclick="window.print()">🖨️ Print</button>
              </div>
            </details>

          </article>
        <% }) %>
      </section>
    </main>

    <%- include('partials/footer') %>
  </body>
</html>