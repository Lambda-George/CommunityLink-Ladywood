<!DOCTYPE html>
<html lang="en">
  <%- include('partials/head') %>

  <body>
    <%- include('partials/nav') %>

    <main>

      <div class="home-search">
        <form action="/services" method="GET" class="home-search-form">
          <input
            type="text"
            name="search"
            placeholder="Search services, food support, digital help..."
          />
          <button type="submit">Search</button>
        </form>
      </div>

      <div class="home-container">

        <a href="/services?category=Energy" class="home-box box-energy">
          <img src="/images/energy.jpg" alt="Energy and Sustainability">
          <span class="home-box-icon">⚡</span>
          <h3>Energy and Sustainability</h3>
        </a>

        <a href="/services?category=Digital Help" class="home-box box-digital">
          <img src="/images/digitalresources.jpg" alt="Digital Resources">
          <span class="home-box-icon">💻</span>
          <h3>Digital Resources</h3>
        </a>

        <a href="/services?category=Community Events" class="home-box box-initiatives">
          <img src="/images/community.jpg" alt="Initiatives and community Projects">
          <span class="home-box-icon">🤝</span>
          <h3>Initiatives and Community Projects</h3>
        </a>

        <a href="/services?category=Food Support" class="home-box box-food">
          <img src="/images/foodsupport.jpg" alt="Food Support">
          <span class="home-box-icon">🍽️</span>
          <h3>Food Support</h3>
        </a>

        <a href="/services" class="home-box box-council">
          <img src="/images/citycouncil.jpg" alt="city council">
          <span class="home-box-icon">🏛️</span>
          <h3>Birmingham City Council</h3>
        </a>

        <a href="/services" class="home-box box-waste">
          <img src="/images/waste.jpg" alt="Managing Waste">
          <span class="home-box-icon">♻️</span>
          <h3>Managing Waste</h3>
        </a>

        <a href="/services" class="home-box box-findlocal">
          <img src="/images/localservices.jpg" alt="Local Services">
          <span class="home-box-icon">📍</span>
          <h3>Find Local Services</h3>
        </a>

      </div>

    </main>

    <%- include('partials/footer') %>
  </body>
</html>
